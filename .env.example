# EduRAG environment template
# Copy this file to .env and fill your real values.

# LLM
EDURAG_LLM_MODEL=qwen-plus
EDURAG_DASHSCOPE_API_KEY=demo-key-change-me
EDURAG_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EDURAG_DEEPSEEK_API_KEY=demo-key-change-me
EDURAG_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Auth
EDURAG_JWT_SECRET=demo-jwt-secret-change-me
EDURAG_DEFAULT_SUPERVISOR_PASSWORD=demo-supervisor-pass-change-me

# Data services
EDURAG_MYSQL_HOST=localhost
EDURAG_MYSQL_USER=root
EDURAG_MYSQL_PASSWORD=demo-mysql-password
EDURAG_MYSQL_DATABASE=subjects_kg
EDURAG_REDIS_HOST=localhost
EDURAG_REDIS_PORT=6379
EDURAG_REDIS_PASSWORD=demo-redis-password
EDURAG_REDIS_DB=0

# Milvus
EDURAG_MILVUS_HOST=localhost
EDURAG_MILVUS_PORT=19530
EDURAG_MILVUS_DATABASE_NAME=itcast
EDURAG_MILVUS_COLLECTION_NAME=edurag_final

# Retrieval
EDURAG_PARENT_CHUNK_SIZE=1200
EDURAG_CHILD_CHUNK_SIZE=300
EDURAG_CHUNK_OVERLAP=50
EDURAG_RETRIEVAL_K=5
EDURAG_CANDIDATE_M=2
EDURAG_VALID_SOURCES=mining

# App
EDURAG_CUSTOMER_SERVICE_PHONE=400-000-0000
EDURAG_LOG_FILE=logs/app.log
